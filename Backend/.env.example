# Application
APP_NAME=JobMatch API
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# Comma-separated origins for CORS (React web + Flutter web/debug builds)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# PostgreSQL connection URL
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+psycopg2://jobmatch:jobmatch@localhost:5432/jobmatch

# JWT settings (use a long random secret in production)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# RapidAPI / JSearch
RAPIDAPI_KEY=your-rapidapi-key-here
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com
JSEARCH_HOST=jsearch.p.rapidapi.com
JOB_SEARCH_CACHE_TTL_SECONDS=300

# Resume upload limits
MAX_RESUME_SIZE_MB=5

# Match scoring weights (must sum to 1.0 for intuitive weighting)
KEYWORD_SCORE_WEIGHT=0.4
SEMANTIC_SCORE_WEIGHT=0.6
